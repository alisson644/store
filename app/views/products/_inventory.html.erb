<% if product.inventory_count.positive? %>
  <p><%= product.inventory_count %> in stock</p>
<% else %>
  <p>Out of Stock</p>
  <p>Email me when available.</p>
  <%= form_with model: [product, Subscriber.new] do |f| %>
    <%= f.email_field :email, placeholder: "Enter your email" %>
    <%= f.submit "Notify Me" %>
  <% end %>
<% end %>